# OrthoSec configuration — copy to .env and fill in.
# The core scanner runs WITHOUT any of this. These only power the executive
# LLM narrative + free-form Q&A (the `orthosec[intel]` extra).

# Anthropic API key for the executive intel layer.
# Get one at https://console.anthropic.com/  (never commit the real .env)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Azure AI Foundry — serves Claude via the Anthropic Messages API.
# Uses Azure model ids: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5.
AZURE_API_KEY=
AZURE_BASE_URL=
# Comma-separated Azure deployment ids you actually have (probe: only sonnet-4-6 today).
AZURE_MODELS=

# Optional: which Claude model narrates the executive briefing.
# Default is claude-opus-4-8. Use claude-sonnet-5 for lower cost.
# ORTHOSEC_MODEL=claude-opus-4-8

# Optional: point OrthoSec at a specific .env instead of ./.env
# ORTHOSEC_ENV=/path/to/custom.env
