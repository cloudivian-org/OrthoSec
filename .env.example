# OrthoSec configuration — copy to .env and fill in.
# The core scanner runs WITHOUT any of this. These only power the executive
# LLM narrative + free-form Q&A (the `orthosec[intel]` extra).

# Anthropic API key for the executive intel layer.
# Get one at https://console.anthropic.com/  (never commit the real .env)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Azure AI Foundry — serves Claude via the Anthropic Messages API.
# Uses Azure model ids: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5.
AZURE_API_KEY=
AZURE_BASE_URL=
# Comma-separated Azure deployment ids you actually have (probe: only sonnet-4-6 today).
AZURE_MODELS=

# Optional: which Claude model narrates the executive briefing.
# Default is claude-opus-4-8. Use claude-sonnet-5 for lower cost.
# ORTHOSEC_MODEL=claude-opus-4-8

# Optional: point OrthoSec at a specific .env instead of ./.env
# ORTHOSEC_ENV=/path/to/custom.env

# --- Scheduling (orthosec watch / schedule) ---------------------------------
# Defaults for scheduled scans. CLI flags (--every, --report-dir, --cron,
# --profile) always override these; these override the built-in defaults.
# Interval for `orthosec watch`: 45s | 30m | 6h | 1d. Daily report = 1d.
# ORTHOSEC_WATCH_EVERY=1d
# Directory where `orthosec watch` writes report-<ts>.html + latest.html/json.
# ORTHOSEC_REPORT_DIR=orthosec-reports
# Cron expression printed by `orthosec schedule` (default: 9am daily).
# ORTHOSEC_CRON=0 9 * * *
# Default audience profile: engineer | appsec | ciso | product.
# ORTHOSEC_PROFILE=appsec

# --- Reporting (orthosec scan) ----------------------------------------------
# Every `orthosec scan` writes the full HTML report by default. These pin that
# behavior via .env so no flags are needed. --html / --no-report / --open override.
# Where the HTML report is written each scan (set to "off" to disable).
# ORTHOSEC_REPORT=orthosec-report.html
# Open the report in your browser automatically after each scan.
# ORTHOSEC_OPEN=1
# Set to 1 to skip the LLM executive briefing (faster, fully offline). Leave unset
# to include the full report (grounded exec narrative) when an API key is present.
# ORTHOSEC_NO_EXEC=0
